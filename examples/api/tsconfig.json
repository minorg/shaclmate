{
  "compilerOptions": {
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "noUncheckedIndexedAccess": false,
    "types": [
      "node"
    ]
  },
  "extends": [
    "@tsconfig/strictest/tsconfig.json",
    "@tsconfig/node20/tsconfig.json"
  ],
  "include": [
    "src/**/*.ts"
  ]
}