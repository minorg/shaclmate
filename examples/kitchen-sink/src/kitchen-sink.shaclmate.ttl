@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix : <http://example.com/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shaclmate: <http://purl.org/shaclmate/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:AnonymousTypesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with anonymous property types." ;
    sh:property [
        rdfs:comment "Anonymous struct node shape" ;
        sh:maxCount 1 ;
        sh:node [
            sh:property [
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:path :anonymousStructString
            ]
        ] ;
        sh:path :anonymousStruct
    ] .

:BlankNodeIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape that can only have a blank node as an identifier" ;
    sh:nodeKind sh:BlankNode ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :blankNodeIdentifierString
    ] .

:BlankNodeOrIriIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape that can have a blank node or IRI as an identifier" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :blankNodeOrIriIdentifierString
    ] .

:ClassConstraintsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with sh:class properties" ;
    sh:property [
        rdfs:comment "Property where sh:class refers to multiple undefined classes; sh:nodeKind is implicit sh:BlankNodeOrIRI" ;
        sh:class :UndefinedClass1, :UndefinedClass2 ;
        sh:maxCount 1 ;
        sh:path :multiClass
    ], [
        rdfs:comment "Property where sh:class refers to an undefined :Class sh:nodeKind is an IRI" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :iriClass
    ], [
        rdfs:comment "Property where sh:class refers to an undefined :Class and sh:node refers to a node shape that's not an implicit class target" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:node :NonClassStruct ;
        sh:path :nodeClass1
    ], [
        rdfs:comment "Property where sh:class refers to an undefined :Class and sh:node refers to a node shape that is an implicit class target" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:node :PartialStruct ;
        sh:path :nodeClass2
    ], [
        rdfs:comment "Property where sh:class refers to a single undefined :UndefinedClass; sh:nodeKind is implicit sh:BlankNodeOrIRI" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:path :singleClass
    ] .

:ConvertibleTypesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with properties whose types are convertible from other types on construction e.g., string to IRI." ;
    sh:property [
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIriOption
    ], [
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIriSet
    ], [
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIriNonEmptySet
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteral
    ], [
        sh:maxCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteralOption
    ], [
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteralSet
    ], [
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteralNonEmptySet
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :convertibleTerm
    ], [
        sh:maxCount 1 ;
        sh:path :convertibleTermOption
    ], [
        sh:path :convertibleTermSet
    ], [
        sh:minCount 1 ;
        sh:path :convertibleTermNonEmptySet
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIri
    ] .

:DateUnionsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with sh:xone (union) properties related to dates and date-times. Unions of these and strings are common in actual models." ;
    sh:property [
        sh:maxCount 1 ;
        sh:path :dateOrDateTime ;
        sh:xone ([
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
            [
                shaclmate:discriminantValue "dateTime" ;
                sh:datatype xsd:dateTime
            ]
        )
    ], [
        sh:maxCount 1 ;
        sh:path :dateTimeOrDate ;
        sh:xone ([
                shaclmate:discriminantValue "dateTime" ;
                sh:datatype xsd:dateTime
            ]
            [
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
        )
    ], [
        sh:maxCount 1 ;
        sh:path :dateOrString ;
        sh:xone ([
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
            [
                shaclmate:discriminantValue "string" ;
                sh:datatype xsd:string
            ]
        )
    ], [
        sh:maxCount 1 ;
        sh:path :stringOrDate ;
        sh:xone ([
                shaclmate:discriminantValue "string" ;
                sh:datatype xsd:string
            ]
            [
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
        )
    ] .

:DefaultValuesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with sh:defaultValue properties." ;
    sh:property [
        sh:defaultValue "" ;
        sh:maxCount 1 ;
        sh:path :stringDefaultValue
    ], [
        sh:defaultValue true ;
        sh:maxCount 1 ;
        sh:path :trueBooleanDefaultValue
    ], [
        sh:defaultValue false ;
        sh:maxCount 1 ;
        sh:path :falseBooleanDefaultValue
    ], [
        sh:defaultValue "2018-04-09"^^xsd:date ;
        sh:maxCount 1 ;
        sh:path :dateDefaultValue
    ], [
        sh:defaultValue "2018-04-09T10:00:00Z"^^xsd:dateTime ;
        sh:maxCount 1 ;
        sh:path :dateTimeDefaultValue
    ], [
        sh:defaultValue 0.0e0 ;
        sh:maxCount 1 ;
        sh:path :numberDefaultValue
    ] .

:DirectRecursiveStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :DirectRecursiveStruct ;
        sh:path :directRecursive
    ] .

:DisplayStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Demonstrates the use of shaclmate:display for excluding/including properties from toString()-type display representations" ;
    sh:property [
        shaclmate:display false ;
        rdfs:comment "Explicity exclude from the display" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitFalseDisplay
    ], [
        shaclmate:display true ;
        rdfs:comment "Explicity include in the display" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitTrueDisplay
    ], [
        rdfs:comment "Implicitly exclude from the display" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :implicitFalseDisplay
    ] .

:ExplicitFromToRdfTypesStruct
    shaclmate:fromRdfType :FromRdfType ;
    shaclmate:toRdfType :ToRdfType ;
    a owl:Class, sh:NodeShape ;
    rdfs:comment """Struct node shape with custom rdf:type's.

The shaclmate:fromRdfType is expected on deserialization.
shaclmate:toRdfType's are added an serialization.""" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitFromToRdfTypesString
    ] .

:ExplicitRdfTypeStruct
    shaclmate:rdfType :RdfType ;
    a owl:Class, sh:NodeShape ;
    rdfs:comment """Struct node shape with custom rdf:type's.

The shaclmate:rdfType is expected on deserialization and added on serialization.""" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitRdfTypeString
    ] .

:FlattenUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape that unions a node shape and another union of node shapes. Generated code will usually flatten these." ;
    sh:xone (:Union
        :FlattenUnionMember3
    ) .

:FlattenUnionMember3
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :flattenUnionMember3String
    ] .

:HasValuesStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape with sh:hasValue properties." ;
    sh:property [
        sh:hasValue :HasValuesStructIri1 ;
        sh:maxCount 1 ;
        sh:path :hasIriValue
    ], [
        sh:hasValue "test" ;
        sh:maxCount 1 ;
        sh:path :hasLiteralValue
    ] .

:IgnoredPropertiesStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape that uses different methods to make SHACLmate ignore properties." ;
    sh:property [
        rdfs:comment "A property without an sh:severity defaults to sh:Violation severity and is not ignored" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :severityDefaultProperty
    ], [
        rdfs:comment "A property with an explicit sh:severity sh:Violation is not ignored" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :severityViolationProperty ;
        sh:severity sh:Violation
    ], [
        rdfs:comment "A property with an explicit sh:severity sh:Info is ignored" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :severityInfoProperty ;
        sh:severity sh:Info
    ], [
        rdfs:comment "A property with an explicit sh:severity sh:Warning is ignored" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :severityWarningProperty ;
        sh:severity sh:Info
    ], [
        shaclmate:ignore false ;
        rdfs:comment "A property with shaclmate:ignore set to false (the default) is not ignored" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :shaclmateIgnoreFalseProperty
    ], [
        shaclmate:ignore true ;
        rdfs:comment "A property with shaclmate:ignore set to true not ignored" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :shaclmateIgnoreTrueProperty
    ] .

:InIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with sh:in constraining its identifier." ;
    sh:in (:InIdentifierStructInstance1
        :InIdentifierStructInstance2
    ) ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :inIdentifierString
    ] .

:InPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with sh:in properties." ;
    sh:property [
        sh:in (1e0
            2e0
        ) ;
        sh:maxCount 1 ;
        sh:path :inDoubles
    ], [
        sh:in ("text"
            "html"
        ) ;
        sh:maxCount 1 ;
        sh:path :inStrings
    ], [
        sh:in (true
        ) ;
        sh:maxCount 1 ;
        sh:path :inBooleans
    ], [
        sh:in ("2018-04-09T10:00:00.000Z"^^xsd:dateTime
        ) ;
        sh:maxCount 1 ;
        sh:path :inDateTimes
    ], [
        sh:in (1
            2
        ) ;
        sh:maxCount 1 ;
        sh:path :inIntegers
    ], [
        sh:in (:InIri1
            :InIri2
        ) ;
        sh:maxCount 1 ;
        sh:path :inIris
    ], [
        sh:maxCount 1 ;
        sh:node :ReusableIn ;
        sh:path :reusableIn
    ] .

:IndirectRecursiveStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :IndirectRecursiveStructHelper ;
        sh:path :indirectRecursiveHelper
    ] .

:IndirectRecursiveStructHelper
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :IndirectRecursiveStruct ;
        sh:path :indirectRecursive
    ] .

:IriIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "A node shape that only allows IRI identifiers." ;
    sh:nodeKind sh:IRI ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :iriIdentifierString
    ] .

:IriList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of IRIs. Should be transformed into a list data structure when used as a property.", "A node shape that models an RDF list of strings. The generated list code should be mutable." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:nodeKind sh:IRI ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :IriList ;
                sh:path rdf:rest
            ]
        ]
    ), ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:nodeKind sh:IRI ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :IriList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:LanguageInStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape that uses the StringList in a property." ;
    sh:property [
        rdfs:comment "literal property for testing languageIn" ;
        sh:languageIn ("en"
            "fr"
        ) ;
        sh:minCount 1 ;
        sh:path :languageInLiteral
    ] .

:LazilyResolvedBlankNodeOrIriIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape resolved by LazyPropertiesStruct" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolved
    ] .

:LazilyResolvedIriIdentifierStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape resolved by LazyPropertiesStruct" ;
    sh:nodeKind sh:IRI ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolved
    ] .

:LazilyResolvedUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape that sh:xone's other node shapes. This will usually be generated as a discriminated union." ;
    sh:xone (:LazilyResolvedUnionMember1
        :LazilyResolvedUnionMember2
    ) .

:LazilyResolvedUnionMember1
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolved
    ] .

:LazilyResolvedUnionMember2
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolved
    ] .

:LazyPropertiesStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape that has lazy properties." ;
    sh:property [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :requiredLazyToResolvedBlankNodeOrIriIdentifier
    ], [
        shaclmate:resolve :LazilyResolvedIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :optionalLazyToResolvedIriIdentifier
    ], [
        shaclmate:resolve :LazilyResolvedUnion ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :optionalLazyToResolvedUnion
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 0 ;
        sh:node :PartialStruct ;
        sh:path :optionalPartialToResolvedBlankNodeOrIriIdentifier
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:node :PartialStruct ;
        sh:path :setPartialToResolvedBlankNodeOrIriIdentifier
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:node :PartialStruct ;
        sh:path :requiredPartialToResolvedBlankNodeOrIriIdentifier
    ], [
        shaclmate:resolve :LazilyResolvedUnion ;
        sh:maxCount 1 ;
        sh:node :PartialStruct ;
        sh:path :optionalPartialToResolvedUnion
    ], [
        shaclmate:resolve :LazilyResolvedUnion ;
        sh:maxCount 1 ;
        sh:node :PartialUnion ;
        sh:path :optionalPartialUnionToResolvedUnion
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 0 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :optionalLazyToResolvedBlankNodeOrIriIdentifier
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :setLazyToResolvedBlankNodeOrIriIdentifier
    ] .

:ListSetsStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        rdfs:comment "Set of lists" ;
        sh:node :StringList ;
        sh:path :listSet
    ], [
        rdfs:comment "Set of lists of lists" ;
        sh:node :StringListList ;
        sh:path :listListSet
    ], [
        rdfs:comment "Set of typeof union that includes a list" ;
        sh:path :listUnionSet ;
        sh:xone ([
                sh:node :StringList
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ] .

:ListsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape that uses the list shapes in properties." ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :StructList ;
        sh:path :structList
    ], [
        sh:maxCount 1 ;
        sh:node :IriList ;
        sh:path :iriList
    ], [
        sh:maxCount 1 ;
        sh:node :StringList ;
        sh:path :stringList
    ], [
        sh:maxCount 1 ;
        sh:node :StringListList ;
        sh:path :stringListList
    ] .

:MutablePropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with shaclmate:mutable properties." ;
    sh:property [
        shaclmate:mutable true ;
        sh:datatype xsd:string ;
        sh:description "String-valued property that can be re-assigned" ;
        sh:maxCount 1 ;
        sh:path :mutableString
    ], [
        sh:description "List-valued property that can't be reassigned but whose value can be mutated" ;
        sh:maxCount 1 ;
        sh:node :MutableStringList ;
        sh:path :mutableList
    ], [
        shaclmate:mutable true ;
        sh:datatype xsd:string ;
        sh:description "Set-valued property that can't be reassigned but whose value can be mutated" ;
        sh:path :mutableSet
    ] .

:MutableStringList
    shaclmate:mutable true ;
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of strings. Should be transformed into a mutable list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :MutableStringList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:NamedUnion1
    a sh:NodeShape ;
    rdfs:comment "Named union of IRI and string" ;
    sh:xone ([
            sh:nodeKind sh:IRI
        ]
        [
            sh:datatype xsd:string
        ]
    ) .

:NamedUnion2
    a sh:NodeShape ;
    rdfs:comment "Named union of date and date-time" ;
    sh:xone ([
            shaclmate:discriminantValue "date" ;
            sh:datatype xsd:date
        ]
        [
            shaclmate:discriminantValue "dateTime" ;
            sh:datatype xsd:dateTime
        ]
    ) .

:NamedUnionsStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:node :NamedUnion1 ;
        sh:path :namedUnion1
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:node :NamedUnion2 ;
        sh:path :namedUnion2
    ] .

:NoRdfTypeUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape that sh:xone's other node shapes. These don't have RDF types since they're not owl:Class's" ;
    sh:xone (:NoRdfTypeUnionMember1
        :NoRdfTypeUnionMember2
    ) .

:NoRdfTypeUnionMember1
    a sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :noRdfTypeUnionMember1String
    ] .

:NoRdfTypeUnionMember2
    a sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :noRdfTypeUnionMember2String
    ] .

:NodeKindsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape that has properties with different sh:nodeKind combinations" ;
    sh:property [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNode ;
        sh:path :blankNodeKind
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :blankNodeOrIriNodeKind
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrLiteral ;
        sh:path :blankNodeOrLiteralNodeKind
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :iriNodeKind
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRIOrLiteral ;
        sh:path :iriOrLiteralNodeKind
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :literalNodeKind
    ] .

:NonClassStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape that isn't an rdfs:Class." ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :nonClassString
    ] .

:NumericsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with properties that have numeric sh:datatype's" ;
    sh:property [
        sh:datatype xsd:byte ;
        sh:maxCount 1 ;
        sh:path :byteNumeric
    ], [
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:path :decimalNumeric
    ], [
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:path :doubleNumeric
    ], [
        sh:datatype xsd:float ;
        sh:maxCount 1 ;
        sh:path :floatNumeric
    ], [
        sh:datatype xsd:int ;
        sh:maxCount 1 ;
        sh:path :intNumeric
    ], [
        sh:datatype xsd:integer ;
        sh:maxCount 1 ;
        sh:path :integerNumeric
    ], [
        sh:datatype xsd:long ;
        sh:maxCount 1 ;
        sh:path :longNumeric
    ], [
        sh:datatype xsd:negativeInteger ;
        sh:maxCount 1 ;
        sh:path :negativeIntegerNumeric
    ], [
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:path :nonNegativeIntegerNumeric
    ], [
        sh:datatype xsd:nonPositiveInteger ;
        sh:maxCount 1 ;
        sh:path :nonPositiveIntegerNumeric
    ], [
        sh:datatype xsd:positiveInteger ;
        sh:maxCount 1 ;
        sh:path :positiveIntegerNumeric
    ], [
        sh:datatype xsd:short ;
        sh:maxCount 1 ;
        sh:path :shortNumeric
    ], [
        sh:datatype xsd:unsignedByte ;
        sh:maxCount 1 ;
        sh:path :unsignedByteNumeric
    ], [
        sh:datatype xsd:unsignedInt ;
        sh:maxCount 1 ;
        sh:path :unsignedIntNumeric
    ], [
        sh:datatype xsd:unsignedLong ;
        sh:maxCount 1 ;
        sh:path :unsignedLongNumeric
    ], [
        sh:datatype xsd:unsignedShort ;
        sh:maxCount 1 ;
        sh:path :unsignedShortNumeric
    ] .

:OrderedStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape whose sh:properties have sh:order's. The compiler should order them C, A, B based on sh:order instead of on the declaration or lexicographic orders." ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:order 1 ;
        sh:path :orderedC
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:order 3 ;
        sh:path :orderedA
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:order 2 ;
        sh:path :orderedB
    ] .

:OverrideNameStruct
    shaclmate:name "NewName" ;
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape that overrides its default name (derived from the identifier) using shaclmate:name; sh:name is only for property shapes" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :newNameString
    ] .

:PartialStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape used as a partial by LazyPropertiesStruct" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolved
    ] .

:PartialUnion
    a sh:NodeShape ;
    rdfs:comment "Counterpart of Union for lazy resolution. The partial union must have the same number of members, in the corresponding order, as the 'full' union." ;
    sh:xone (:PartialUnionMember1
        :PartialUnionMember2
    ) .

:PartialUnionMember1
    shaclmate:rdfType :UnionMember1 ;
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolved
    ] .

:PartialUnionMember2
    shaclmate:rdfType :UnionMember2 ;
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolved
    ] .

:PropertyCardinalitiesStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape that has properties with different cardinalities" ;
    sh:property [
        rdfs:comment "Required: maxCount=minCount=1" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :required
    ], [
        rdfs:comment "Option: maxCount=1, minCount=0" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 0 ;
        sh:path :optional
    ], [
        rdfs:comment "Set: minCount implicitly=0, no maxCount" ;
        sh:datatype xsd:string ;
        sh:path :emptySet
    ], [
        rdfs:comment "Set: minCount=1, no maxCount" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:path :nonEmptySet
    ] .

:PropertyNamesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape that uses different methods to name properties" ;
    sh:property :PropertyNamesStruct-actualName5, [
        rdfs:comment "sh:path: overrides property shape identifier" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :actualName1
    ], [
        rdfs:comment "sh:name: overrides sh:path and rdfs:label" ;
        rdfs:label "ignoreName2" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:name "actualName2" ;
        sh:path :ignoreName2
    ], [
        shaclmate:name "actualName3" ;
        rdfs:comment "shaclmate:name: overrides sh:name, sh:path, and rdfs:label" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:name "ignoreName3" ;
        sh:path :ignoreName3
    ], [
        rdfs:comment "rdfs:label: overrides sh:path" ;
        rdfs:label "actualName4" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :ignoreName4
    ] .

:PropertyNamesStruct-actualName5
    a sh:PropertyShape ;
    rdfs:comment "IRI shape identifier whose prefix is a node shape identifier IRI: overrides sh:path" ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:path :ignoreName5 .

:PropertyPathsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape that uses different property path types in its properties" ;
    sh:property [
        sh:maxCount 1 ;
        sh:name "inversePath" ;
        sh:nodeKind sh:IRI ;
        sh:path [
            sh:inversePath :inversePath
        ]
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :predicatePath
    ] .

:RecursiveUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape that sh:xone's node shapes that have properties with the union's type" ;
    sh:xone (:RecursiveUnionMember1
        :RecursiveUnionMember2
    ) .

:RecursiveUnionMember1
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :RecursiveUnion ;
        sh:path :recursiveUnionMember1Property
    ] .

:RecursiveUnionMember2
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :RecursiveUnion ;
        sh:path :recursiveUnionMember2Property
    ] .

:ReusableIn
    a sh:NodeShape ;
    rdfs:comment "Reusable sh:in with a name to use in lieu of inline types." ;
    sh:in ("cat"
        "dog"
    ) .

:StringList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of strings. Should be transformed into a list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StringList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:StringListList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of string lists. Should be transformed into a list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StringList ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StringListList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:StructList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of objects. Should be transformed into a mutable list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :NonClassStruct ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StructList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:TermsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Struct node shape with properties that are not nested objects" ;
    sh:property [
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNode ;
        sh:path :blankNodeTerm
    ], [
        sh:datatype xsd:boolean ;
        sh:maxCount 1 ;
        sh:path :booleanTerm
    ], [
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
        sh:path :dateTerm
    ], [
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:path :dateTimeTerm
    ], [
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:path :numberTerm
    ], [
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :iriTerm
    ], [
        sh:maxCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :literalTerm
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :stringTerm
    ], [
        sh:maxCount 1 ;
        sh:path :term
    ] .

:Union
    a sh:NodeShape ;
    rdfs:comment "Node shape that sh:xone's other node shapes. This will usually be generated as a discriminated union." ;
    sh:xone (:UnionMember1
        :UnionMember2
    ) .

:UnionDiscriminantsStruct
    a sh:NodeShape ;
    rdfs:comment "Struct node shape shape with sh:xone (union) properties with different discriminant types (extrinsic, hybrid, intrinsic, typeof) x cardinality." ;
    sh:property [
        rdfs:comment "Union with an extrinsic discriminant (multiple+duplicate typeofs, no intrinsic discriminant property)." ;
        sh:maxCount 1 ;
        sh:path :optionalNodeOrNodeOrString ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:node :UnionMember2
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType)." ;
        sh:maxCount 1 ;
        sh:path :optionalIriOrLiteral ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType) for RDF/JS term members and an extrinsic on termType for other members." ;
        sh:maxCount 1 ;
        sh:path :optionalNodeOrLiteral ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by typeof." ;
        sh:maxCount 1 ;
        sh:path :optionalIriOrString ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType) for RDF/JS term members and an extrinsic on termType for other members." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredNodeOrLiteral ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union with an extrinsic discriminant (multiple typeofs, no intrinsic discriminant property)." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredNodeOrNodeOrString ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:node :UnionMember2
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType) for RDF/JS term members and an extrinsic on termType for other members." ;
        sh:path :setNodeOrLiteral ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType)." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredIriOrLiteral ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by typeof." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredIriOrString ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union with an extrinsic discriminant (multiple typeofs, no intrinsic discriminant property)." ;
        sh:path :setNodeOrNodeOrString ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:node :UnionMember2
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType)." ;
        sh:path :setIriOrLiteral ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by typeof." ;
        sh:path :setIriOrString ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ] .

:UnionMember-common
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "unionMemberCommon" ;
    sh:path :unionMemberCommon .

:UnionMember1
