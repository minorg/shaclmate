@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix : <http://example.com/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shaclmate: <http://purl.org/shaclmate/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:BlankNodeIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape that can only have a blank node as an identifier" ;
    sh:nodeKind sh:BlankNode ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :blankNodeIdentifierProperty
    ] .

:BlankNodeOrIriIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape that can have a blank node or IRI as an identifier" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :blankNodeOrIriIdentifierProperty
    ] .

:ClassPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with sh:class properties" ;
    sh:property [
        rdfs:comment "Property where sh:class refers to multiple undefined classes; sh:nodeKind is implicit sh:BlankNodeOrIRI" ;
        sh:class :UndefinedClass1, :UndefinedClass2 ;
        sh:maxCount 1 ;
        sh:path :multiClassProperty
    ], [
        rdfs:comment "Property where sh:class refers to an undefined :Class sh:nodeKind is an IRI" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :iriClassProperty
    ], [
        rdfs:comment "Property where sh:class refers to an undefined :Class and sh:node refers to a node shape that's not an implicit class target" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:node :NonClass ;
        sh:path :nodeClassProperty1
    ], [
        rdfs:comment "Property where sh:class refers to an undefined :Class and sh:node refers to a node shape that is an implicit class target" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:node :PartialStruct ;
        sh:path :nodeClassProperty2
    ], [
        rdfs:comment "Property where sh:class refers to a single undefined :UndefinedClass; sh:nodeKind is implicit sh:BlankNodeOrIRI" ;
        sh:class :UndefinedClass ;
        sh:maxCount 1 ;
        sh:path :singleClassProperty
    ] .

:ConvertibleTypePropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with properties whose types are convertible from other types on construction e.g., string to IRI." ;
    sh:property [
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIriOptionProperty
    ], [
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIriSetProperty
    ], [
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIriNonEmptySetProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteralProperty
    ], [
        sh:maxCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteralOptionProperty
    ], [
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteralSetProperty
    ], [
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :convertibleLiteralNonEmptySetProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :convertibleTermProperty
    ], [
        sh:maxCount 1 ;
        sh:path :convertibleTermOptionProperty
    ], [
        sh:path :convertibleTermSetProperty
    ], [
        sh:minCount 1 ;
        sh:path :convertibleTermNonEmptySetProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :convertibleIriProperty
    ] .

:DateUnionPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with sh:xone (union) properties related to dates and date-times. Unions of these and strings are common in actual models." ;
    sh:property [
        sh:maxCount 1 ;
        sh:path :dateOrDateTimeProperty ;
        sh:xone ([
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
            [
                shaclmate:discriminantValue "dateTime" ;
                sh:datatype xsd:dateTime
            ]
        )
    ], [
        sh:maxCount 1 ;
        sh:path :dateTimeOrDateProperty ;
        sh:xone ([
                shaclmate:discriminantValue "dateTime" ;
                sh:datatype xsd:dateTime
            ]
            [
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
        )
    ], [
        sh:maxCount 1 ;
        sh:path :dateOrStringProperty ;
        sh:xone ([
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
            [
                shaclmate:discriminantValue "string" ;
                sh:datatype xsd:string
            ]
        )
    ], [
        sh:maxCount 1 ;
        sh:path :stringOrDateProperty ;
        sh:xone ([
                shaclmate:discriminantValue "string" ;
                sh:datatype xsd:string
            ]
            [
                shaclmate:discriminantValue "date" ;
                sh:datatype xsd:date
            ]
        )
    ] .

:DefaultValuePropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with sh:defaultValue properties." ;
    sh:property [
        sh:defaultValue "" ;
        sh:maxCount 1 ;
        sh:path :stringDefaultValueProperty
    ], [
        sh:defaultValue true ;
        sh:maxCount 1 ;
        sh:path :trueBooleanDefaultValueProperty
    ], [
        sh:defaultValue false ;
        sh:maxCount 1 ;
        sh:path :falseBooleanDefaultValueProperty
    ], [
        sh:defaultValue "2018-04-09"^^xsd:date ;
        sh:maxCount 1 ;
        sh:path :dateDefaultValueProperty
    ], [
        sh:defaultValue "2018-04-09T10:00:00Z"^^xsd:dateTime ;
        sh:maxCount 1 ;
        sh:path :dateTimeDefaultValueProperty
    ], [
        sh:defaultValue 0.0e0 ;
        sh:maxCount 1 ;
        sh:path :numberDefaultValueProperty
    ] .

:DirectRecursiveStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :DirectRecursiveStruct ;
        sh:path :directRecursiveProperty
    ] .

:DisplayPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Demonstrates the use of shaclmate:display for excluding/including properties from toString()-type display representations" ;
    sh:property [
        shaclmate:display false ;
        rdfs:comment "Explicity exclude from the display" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitFalseDisplayProperty
    ], [
        shaclmate:display true ;
        rdfs:comment "Explicity include in the display" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitTrueDisplayProperty
    ], [
        rdfs:comment "Implicitly exclude from the display" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :implicitFalseDisplayProperty
    ] .

:ExplicitFromToRdfTypesStruct
    shaclmate:fromRdfType :FromRdfType ;
    shaclmate:toRdfType :ToRdfType ;
    a owl:Class, sh:NodeShape ;
    rdfs:comment """Node shape with custom rdf:type's.

The shaclmate:fromRdfType is expected on deserialization.
shaclmate:toRdfType's are added an serialization.""" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitFromToRdfTypesProperty
    ] .

:ExplicitRdfTypeStruct
    shaclmate:rdfType :RdfType ;
    a owl:Class, sh:NodeShape ;
    rdfs:comment """Node shape with custom rdf:type's.

The shaclmate:rdfType is expected on deserialization and added on serialization.""" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :explicitRdfTypeProperty
    ] .

:FlattenUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape that unions a node shape and another union of node shapes. Generated code will usually flatten these." ;
    sh:xone (:Union
        :FlattenUnionMember3
    ) .

:FlattenUnionMember3
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :flattenUnionMember3Property
    ] .

:HasValuePropertiesStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape with sh:hasValue properties." ;
    sh:property [
        sh:hasValue :HasValuePropertiesStructIri1 ;
        sh:maxCount 1 ;
        sh:path :hasIriValueProperty
    ], [
        sh:hasValue "test" ;
        sh:maxCount 1 ;
        sh:path :hasLiteralValueProperty
    ] .

:InIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with sh:in constraining its identifier." ;
    sh:in (:InIdentifierStructInstance1
        :InIdentifierStructInstance2
    ) ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :inIdentifierProperty
    ] .

:InPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with sh:in properties." ;
    sh:property [
        sh:in (1e0
            2e0
        ) ;
        sh:maxCount 1 ;
        sh:path :inDoublesProperty
    ], [
        sh:in ("text"
            "html"
        ) ;
        sh:maxCount 1 ;
        sh:path :inStringsProperty
    ], [
        sh:in (true
        ) ;
        sh:maxCount 1 ;
        sh:path :inBooleansProperty
    ], [
        sh:in ("2018-04-09T10:00:00.000Z"^^xsd:dateTime
        ) ;
        sh:maxCount 1 ;
        sh:path :inDateTimesProperty
    ], [
        sh:in (1
            2
        ) ;
        sh:maxCount 1 ;
        sh:path :inIntegersProperty
    ], [
        sh:in (:InPropertiesIri1
            :InPropertiesIri2
        ) ;
        sh:maxCount 1 ;
        sh:path :inIrisProperty
    ] .

:IndirectRecursiveStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :IndirectRecursiveStructHelper ;
        sh:path :indirectRecursiveHelperProperty
    ] .

:IndirectRecursiveStructHelper
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :IndirectRecursiveStruct ;
        sh:path :indirectRecursiveProperty
    ] .

:IriIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "A node shape that only allows IRI identifiers." ;
    sh:nodeKind sh:IRI ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :iriIdentifierProperty
    ] .

:IriList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of IRIs. Should be transformed into a list data structure when used as a property.", "A node shape that models an RDF list of strings. The generated list code should be mutable." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:nodeKind sh:IRI ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :IriList ;
                sh:path rdf:rest
            ]
        ]
    ), ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:nodeKind sh:IRI ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :IriList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:JsPrimitiveUnionPropertyStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with sh:xone (union) properties with JavaScript primitive types (e.g., boolean, number, et al.). Unions of these are common in actual models." ;
    sh:property [
        sh:path :jsPrimitiveUnionProperty ;
        sh:xone ([
                rdfs:comment "JavaScript boolean" ;
                sh:datatype xsd:boolean
            ]
            [
                rdfs:comment "JavaScript number" ;
                sh:datatype xsd:double
            ]
            [
                rdfs:comment "JavaScript string" ;
                sh:datatype xsd:string
            ]
        )
    ] .

:LanguageInPropertiesStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape that uses the StringList in a property." ;
    sh:property [
        rdfs:comment "literal property for testing languageIn" ;
        sh:languageIn ("en"
            "fr"
        ) ;
        sh:minCount 1 ;
        sh:path :languageInLiteralProperty
    ] .

:LazilyResolvedBlankNodeOrIriIdentifierStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape resolved by LazyPropertiesStruct" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolvedProperty
    ] .

:LazilyResolvedIriIdentifierStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape resolved by LazyPropertiesStruct" ;
    sh:nodeKind sh:IRI ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolvedProperty
    ] .

:LazilyResolvedUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape sh:xone's other node shapes. This will usually be generated as a discriminated union." ;
    sh:xone (:LazilyResolvedUnionMember1
        :LazilyResolvedUnionMember2
    ) .

:LazilyResolvedUnionMember1
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolvedProperty
    ] .

:LazilyResolvedUnionMember2
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolvedProperty
    ] .

:LazyPropertiesStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape that has lazy properties." ;
    sh:property [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :requiredLazyToResolvedBlankNodeOrIriIdentifierProperty
    ], [
        shaclmate:resolve :LazilyResolvedIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :optionalLazyToResolvedIriIdentifierProperty
    ], [
        shaclmate:resolve :LazilyResolvedUnion ;
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :optionalLazyToResolvedUnionProperty
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 0 ;
        sh:node :PartialStruct ;
        sh:path :optionalPartialToResolvedBlankNodeOrIriIdentifierProperty
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:node :PartialStruct ;
        sh:path :setPartialToResolvedBlankNodeOrIriIdentifierProperty
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:node :PartialStruct ;
        sh:path :requiredPartialToResolvedBlankNodeOrIriIdentifierProperty
    ], [
        shaclmate:resolve :LazilyResolvedUnion ;
        sh:maxCount 1 ;
        sh:node :PartialStruct ;
        sh:path :optionalPartialToResolvedUnionProperty
    ], [
        shaclmate:resolve :LazilyResolvedUnion ;
        sh:maxCount 1 ;
        sh:node :PartialUnion ;
        sh:path :optionalPartialUnionToResolvedUnionProperty
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:maxCount 1 ;
        sh:minCount 0 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :optionalLazyToResolvedBlankNodeOrIriIdentifierProperty
    ], [
        shaclmate:resolve :LazilyResolvedBlankNodeOrIriIdentifierStruct ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :setLazyToResolvedBlankNodeOrIriIdentifierProperty
    ] .

:ListPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape that uses the list shapes in properties." ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :StructList ;
        sh:path :structListProperty
    ], [
        sh:maxCount 1 ;
        sh:node :IriList ;
        sh:path :iriListProperty
    ], [
        sh:maxCount 1 ;
        sh:node :StringList ;
        sh:path :stringListProperty
    ], [
        sh:maxCount 1 ;
        sh:node :StringListList ;
        sh:path :stringListListProperty
    ] .

:ListSetsStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        rdfs:comment "Set of lists" ;
        sh:node :StringList ;
        sh:path :listSetProperty
    ], [
        rdfs:comment "Set of lists of lists" ;
        sh:node :StringListList ;
        sh:path :listListSetProperty
    ], [
        rdfs:comment "Set of typeof union that includes a list" ;
        sh:path :listUnionSetProperty ;
        sh:xone ([
                sh:node :StringList
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ] .

:MutablePropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with shaclmate:mutable properties." ;
    sh:property [
        shaclmate:mutable true ;
        sh:datatype xsd:string ;
        sh:description "String-valued property that can be re-assigned" ;
        sh:maxCount 1 ;
        sh:path :mutableStringProperty
    ], [
        sh:description "List-valued property that can't be reassigned but whose value can be mutated" ;
        sh:maxCount 1 ;
        sh:node :MutableStringList ;
        sh:path :mutableListProperty
    ], [
        shaclmate:mutable true ;
        sh:datatype xsd:string ;
        sh:description "Set-valued property that can't be reassigned but whose value can be mutated" ;
        sh:path :mutableSetProperty
    ] .

:MutableStringList
    shaclmate:mutable true ;
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of strings. Should be transformed into a mutable list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :MutableStringList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:NamedUnion1
    a sh:NodeShape ;
    rdfs:comment "Named union of IRI and string" ;
    sh:xone ([
            sh:nodeKind sh:IRI
        ]
        [
            sh:datatype xsd:string
        ]
    ) .

:NamedUnion2
    a sh:NodeShape ;
    rdfs:comment "Named union of date and date-time" ;
    sh:xone ([
            shaclmate:discriminantValue "date" ;
            sh:datatype xsd:date
        ]
        [
            shaclmate:discriminantValue "dateTime" ;
            sh:datatype xsd:dateTime
        ]
    ) .

:NamedUnionPropertiesStruct
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:node :NamedUnion1 ;
        sh:path :namedUnion1Property
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:node :NamedUnion2 ;
        sh:path :namedUnion2Property
    ] .

:NoRdfTypeUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape sh:xone's other node shapes. These don't have RDF types since they're not owl:Class's" ;
    sh:xone (:NoRdfTypeUnionMember1
        :NoRdfTypeUnionMember2
    ) .

:NoRdfTypeUnionMember1
    a sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :noRdfTypeUnionMember1Property
    ] .

:NoRdfTypeUnionMember2
    a sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :noRdfTypeUnionMember2Property
    ] .

:NodeKindsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape that has properties with different sh:nodeKind combinations" ;
    sh:property [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNode ;
        sh:path :blankNodeKindProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:path :blankNodeOrIriNodeKindProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:BlankNodeOrLiteral ;
        sh:path :blankNodeOrLiteralNodeKindProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :iriNodeKindProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:IRIOrLiteral ;
        sh:path :iriOrLiteralNodeKindProperty
    ], [
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :literalNodeKindProperty
    ] .

:NonClassStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape that isn't an rdfs:Class." ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :nonClassProperty
    ] .

:NumericPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with properties that have numeric sh:datatype's" ;
    sh:property [
        sh:datatype xsd:byte ;
        sh:maxCount 1 ;
        sh:path :byteNumericProperty
    ], [
        sh:datatype xsd:decimal ;
        sh:maxCount 1 ;
        sh:path :decimalNumericProperty
    ], [
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:path :doubleNumericProperty
    ], [
        sh:datatype xsd:float ;
        sh:maxCount 1 ;
        sh:path :floatNumericProperty
    ], [
        sh:datatype xsd:int ;
        sh:maxCount 1 ;
        sh:path :intNumericProperty
    ], [
        sh:datatype xsd:integer ;
        sh:maxCount 1 ;
        sh:path :integerNumericProperty
    ], [
        sh:datatype xsd:long ;
        sh:maxCount 1 ;
        sh:path :longNumericProperty
    ], [
        sh:datatype xsd:negativeInteger ;
        sh:maxCount 1 ;
        sh:path :negativeIntegerNumericProperty
    ], [
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:path :nonNegativeIntegerNumericProperty
    ], [
        sh:datatype xsd:nonPositiveInteger ;
        sh:maxCount 1 ;
        sh:path :nonPositiveIntegerNumericProperty
    ], [
        sh:datatype xsd:positiveInteger ;
        sh:maxCount 1 ;
        sh:path :positiveIntegerNumericProperty
    ], [
        sh:datatype xsd:short ;
        sh:maxCount 1 ;
        sh:path :shortNumericProperty
    ], [
        sh:datatype xsd:unsignedByte ;
        sh:maxCount 1 ;
        sh:path :unsignedByteNumericProperty
    ], [
        sh:datatype xsd:unsignedInt ;
        sh:maxCount 1 ;
        sh:path :unsignedIntNumericProperty
    ], [
        sh:datatype xsd:unsignedLong ;
        sh:maxCount 1 ;
        sh:path :unsignedLongNumericProperty
    ], [
        sh:datatype xsd:unsignedShort ;
        sh:maxCount 1 ;
        sh:path :unsignedShortNumericProperty
    ] .

:StructList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of objects. Should be transformed into a mutable list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :NonClass ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StructList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:OrderedPropertiesStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape whose sh:properties have sh:order's. The compiler should order them C, A, B based on sh:order instead of on the declaration or lexicographic orders." ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:order 1 ;
        sh:path :orderedPropertyC
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:order 3 ;
        sh:path :orderedPropertyA
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:order 2 ;
        sh:path :orderedPropertyB
    ] .

:OverrideNameStruct
    shaclmate:name "NewName" ;
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape that overrides its default name (derived from the identifier) using shaclmate:name; sh:name is only for property shapes" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :newNameProperty
    ] .

:PartialStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape used as a partial by LazyPropertiesStruct" ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolvedProperty
    ] .

:PartialUnion
    a sh:NodeShape ;
    rdfs:comment "Counterpart of Union for lazy resolution. The partial union must have the same number of members, in the corresponding order, as the 'full' union." ;
    sh:xone (:PartialUnionMember1
        :PartialUnionMember2
    ) .

:PartialUnionMember1
    shaclmate:rdfType :UnionMember1 ;
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolvedProperty
    ] .

:PartialUnionMember2
    shaclmate:rdfType :UnionMember2 ;
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :lazilyResolvedProperty
    ] .

:PropertyCardinalitiesStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape that has properties with different cardinalities" ;
    sh:property [
        rdfs:comment "Required: maxCount=minCount=1" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredProperty
    ], [
        rdfs:comment "Option: maxCount=1, minCount=0" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 0 ;
        sh:path :optionalProperty
    ], [
        rdfs:comment "Set: minCount implicitly=0, no maxCount" ;
        sh:datatype xsd:string ;
        sh:path :emptySetProperty
    ], [
        rdfs:comment "Set: minCount=1, no maxCount" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:path :nonEmptySetProperty
    ] .

:PropertyNamesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape that uses different methods to name properties" ;
    sh:property :PropertyNamesStruct-actualPropertyName5, [
        rdfs:comment "sh:path: overrides property shape identifier" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :actualPropertyName1
    ], [
        rdfs:comment "sh:name: overrides sh:path and rdfs:label" ;
        rdfs:label "ignorePropertyName2" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:name "actualPropertyName2" ;
        sh:path :ignorePropertyName2
    ], [
        shaclmate:name "actualPropertyName3" ;
        rdfs:comment "shaclmate:name: overrides sh:name, sh:path, and rdfs:label" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:name "ignorePropertyName3" ;
        sh:path :ignorePropertyName3
    ], [
        rdfs:comment "rdfs:label: overrides sh:path" ;
        rdfs:label "actualPropertyName4" ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :ignorePropertyName4
    ] .

:PropertyNamesStruct-actualPropertyName5
    a sh:PropertyShape ;
    rdfs:comment "IRI shape identifier whose prefix is a node shape identifier IRI: overrides sh:path" ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:path :ignorePropertyName5 .

:PropertyPathsStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape that uses different property path types in its properties" ;
    sh:property [
        sh:maxCount 1 ;
        sh:name "inversePathProperty" ;
        sh:nodeKind sh:IRI ;
        sh:path [
            sh:inversePath :inversePathProperty
        ]
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :predicatePathProperty
    ] .

:RecursiveUnion
    a sh:NodeShape ;
    rdfs:comment "Node shape sh:xone's node shapes that have properties with the union's type" ;
    sh:xone (:RecursiveUnionMember1
        :RecursiveUnionMember2
    ) .

:RecursiveUnionMember1
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :RecursiveUnion ;
        sh:path :recursiveUnionMember1Property
    ] .

:RecursiveUnionMember2
    a owl:Class, sh:NodeShape ;
    sh:property [
        sh:maxCount 1 ;
        sh:node :RecursiveUnion ;
        sh:path :recursiveUnionMember2Property
    ] .

:StringList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of strings. Should be transformed into a list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StringList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:StringListList
    a sh:NodeShape ;
    rdfs:comment "A node shape that models an RDF list of string lists. Should be transformed into a list data structure when used as a property." ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StringList ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node :StringListList ;
                sh:path rdf:rest
            ]
        ]
    ) .

:TermPropertiesStruct
    a owl:Class, sh:NodeShape ;
    rdfs:comment "Node shape with properties that are not nested objects" ;
    sh:property [
        sh:maxCount 1 ;
        sh:nodeKind sh:BlankNode ;
        sh:path :blankNodeTermProperty
    ], [
        sh:datatype xsd:boolean ;
        sh:maxCount 1 ;
        sh:path :booleanTermProperty
    ], [
        sh:datatype xsd:date ;
        sh:maxCount 1 ;
        sh:path :dateTermProperty
    ], [
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:path :dateTimeTermProperty
    ], [
        sh:datatype xsd:double ;
        sh:maxCount 1 ;
        sh:path :numberTermProperty
    ], [
        sh:maxCount 1 ;
        sh:nodeKind sh:IRI ;
        sh:path :iriTermProperty
    ], [
        sh:maxCount 1 ;
        sh:nodeKind sh:Literal ;
        sh:path :literalTermProperty
    ], [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:path :stringTermProperty
    ], [
        sh:maxCount 1 ;
        sh:path :termProperty
    ] .

:Union
    a sh:NodeShape ;
    rdfs:comment "Node shape sh:xone's other node shapes. This will usually be generated as a discriminated union." ;
    sh:xone (:UnionMember1
        :UnionMember2
    ) .

:UnionDiscriminantsStruct
    a sh:NodeShape ;
    rdfs:comment "Node shape with sh:xone (union) properties with different discriminant types (extrinsic, hybrid, intrinsic, typeof) x cardinality." ;
    sh:property [
        rdfs:comment "Union with an extrinsic discriminant (multiple+duplicate typeofs, no intrinsic discriminant property)." ;
        sh:maxCount 1 ;
        sh:path :optionalNodeOrNodeOrStringProperty ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:node :UnionMember2
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType)." ;
        sh:maxCount 1 ;
        sh:path :optionalIriOrLiteralProperty ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType) for RDF/JS term members and an extrinsic on termType for other members." ;
        sh:maxCount 1 ;
        sh:path :optionalNodeOrLiteralProperty ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by typeof." ;
        sh:maxCount 1 ;
        sh:path :optionalIriOrStringProperty ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType) for RDF/JS term members and an extrinsic on termType for other members." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredNodeOrLiteralProperty ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union with an extrinsic discriminant (multiple typeofs, no intrinsic discriminant property)." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredNodeOrNodeOrStringProperty ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:node :UnionMember2
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType) for RDF/JS term members and an extrinsic on termType for other members." ;
        sh:path :setNodeOrLiteralProperty ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType)." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredIriOrLiteralProperty ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by typeof." ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :requiredIriOrStringProperty ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union with an extrinsic discriminant (multiple typeofs, no intrinsic discriminant property)." ;
        sh:path :setNodeOrNodeOrStringProperty ;
        sh:xone ([
                sh:node :UnionMember1
            ]
            [
                sh:node :UnionMember2
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by an intrinsic discriminant property (termType)." ;
        sh:path :setIriOrLiteralProperty ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:nodeKind sh:Literal
            ]
        )
    ], [
        rdfs:comment "Union that can be discriminated by typeof." ;
        sh:path :setIriOrStringProperty ;
        sh:xone ([
                sh:nodeKind sh:IRI
            ]
            [
                sh:datatype xsd:string
            ]
        )
    ] .

:UnionMember-commonProperty
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:name "unionMemberCommonProperty" ;
    sh:path :unionMemberCommonProperty .

:UnionMember1
    a owl:Class, sh:NodeShape ;
    sh:property :UnionMember-commonProperty, [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :unionMember1Property
    ] .

:UnionMember2
    a owl:Class, sh:NodeShape ;
    sh:property :UnionMember-commonProperty, [
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:minCount 1 ;
        sh:path :unionMember2Property
    ] .

