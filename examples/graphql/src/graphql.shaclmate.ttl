@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix : <http://example.com/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shaclmate: <http://purl.org/shaclmate/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:LazyObject
    a owl:Class, sh:NodeShape ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:property :optionalNumberProperty, :optionalStringProperty, :requiredStringProperty .

:RootObject
    a owl:Class, sh:NodeShape ;
    sh:nodeKind sh:IRI ;
    sh:property :lazyObjectSetProperty, :optionalLazyProperty, :optionalObjectProperty, :optionalStringProperty, :requiredStringProperty .

:Union
    a owl:Class, sh:NodeShape ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:xone (:UnionMember1
        :UnionMember2
    ) .

:UnionMember1
    a owl:Class, sh:NodeShape ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:property :optionalNumberProperty .

:UnionMember2
    a owl:Class, sh:NodeShape ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:property :optionalStringProperty .

:lazyObjectSetProperty
    shaclmate:resolve :LazyObject ;
    a sh:PropertyShape ;
    rdfs:comment "Lazy object set property" ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path :lazyObjectSetProperty .

:optionalLazyProperty
    shaclmate:resolve :LazyObject ;
    a sh:PropertyShape ;
    rdfs:comment "Optional lazy object property" ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path :optionalLazyProperty .

:optionalNumberProperty
    a sh:PropertyShape ;
    rdfs:comment "Optional number property" ;
    sh:datatype xsd:double ;
    sh:maxCount 1 ;
    sh:path :optionalNumberProperty .

:optionalObjectProperty
    a sh:PropertyShape ;
    rdfs:comment "Optional object property with 'anonymous' object" ;
    sh:maxCount 1 ;
    sh:node [
        sh:nodeKind sh:BlankNodeOrIRI ;
        sh:property :optionalNumberProperty, :optionalStringProperty, :requiredStringProperty
    ] ;
    sh:path :optionalObjectProperty .

:optionalStringProperty
    a sh:PropertyShape ;
    rdfs:comment "Optional string property" ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:path :optionalStringProperty .

:requiredStringProperty
    a sh:PropertyShape ;
    rdfs:comment "Required string property" ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:path :requiredStringProperty .

