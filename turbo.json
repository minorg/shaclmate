{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "clean": {
      "cache": false
    },
    "depcheck": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:tests": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "cache": false,
    },
    "typecheck:watch": {
      "cache": false,
      "persistent": true
    },
  },
  "ui": "tui"
}
