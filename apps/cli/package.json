{
  "bin": {
    "shaclmate": "dist/cli.js"
  },
  "dependencies": {
    "@shaclmate/compiler": "4.0.17",
    "@rdfjs/prefix-map": "~0.1.2",
    "@rdfjs/serializer-turtle": "~1.1.5",
    "@rdfx/fs": "0.0.7",
    "cmd-ts": "~0.15.0",
    "n3": "~1.26.0",
    "pino": "~9.1.0",
    "pino-pretty": "~13.1.2",
    "purify-ts": "~2.1.4",
    "rdf-validate-shacl": "0.6.5",
    "tmp-promise": "~3.0.3",
    "which": "~6.0.1"
  },
  "description": "Command line program to generate TypeScript code from SHACL shapes",
  "devDependencies": {
    "@rdfjs/types": "~2.0.1",
    "@types/n3": "~1.26.0",
    "@types/rdfjs__prefix-map": "~0.1.5",
    "@types/which": "~3.0.4"
  },
  "files": [
    "README.md",
    "dist/*.d.ts",
    "dist/*.js",
    "dist/commands/*.d.ts",
    "dist/commands/*.js"
  ],
  "homepage": "https://github.com/minorg/shaclmate",
  "keywords": [
    "rdf",
    "shacl",
    "typescript"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "name": "@shaclmate/cli",
  "packageManager": "npm@11.11.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minorg/shaclmate.git"
  },
  "scripts": {
    "build": "tsc -b && chmod +x dist/cli.js",
    "clean": "rimraf dist",
    "depcheck": "depcheck .",
    "dev": "tsc -w --preserveWatchOutput",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit -w --preserveWatchOutput"
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "4.0.17"
}
