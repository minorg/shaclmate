    "@rdfjs/dataset": "~2.0.2",
    "@rdfjs/prefix-map": "~0.1.2",
    "@rdfx/data-factory": "0.0.34",
    "@rdfx/fs": "0.0.34",
    "@rdfx/serializers": "0.0.34",
    "cmd-ts": "~0.15.0",
