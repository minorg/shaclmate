@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shaclmate: <http://purl.org/shaclmate/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

shaclmate:NodeShape
    sh:property shaclmate:NodeShape-abstract, shaclmate:NodeShape-discriminantValue, shaclmate:NodeShape-export, shaclmate:NodeShape-extern, shaclmate:NodeShape-fromRdfType, shaclmate:NodeShape-identifierMintingStrategy, shaclmate:NodeShape-rdfType, shaclmate:NodeShape-toRdfTypes, shaclmate:Shape-mutable, shaclmate:Shape-name, shaclmate:tsFeatureExcludes, shaclmate:tsFeatureIncludes, shaclmate:tsImports, shaclmate:tsObjectDeclarationType .

shaclmate:NodeShape-abstract
    a sh:PropertyShape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:path shaclmate:abstract .

shaclmate:NodeShape-discriminantValue
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:path shaclmate:discriminantValue .

shaclmate:NodeShape-export
    shaclmate:name "export_" ;
    a sh:PropertyShape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:path shaclmate:export .

shaclmate:NodeShape-extern
    a sh:PropertyShape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:path shaclmate:extern .

shaclmate:NodeShape-fromRdfType
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path shaclmate:fromRdfType .

shaclmate:NodeShape-identifierMintingStrategy
    a sh:PropertyShape ;
    sh:in (shaclmate:_IdentifierMintingStrategy_BlankNode
        shaclmate:_IdentifierMintingStrategy_SHA256
        shaclmate:_IdentifierMintingStrategy_UUIDv4
    ) ;
    sh:maxCount 1 ;
    sh:path shaclmate:identifierMintingStrategy .

shaclmate:NodeShape-rdfType
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path shaclmate:rdfType .

shaclmate:NodeShape-toRdfTypes
    a sh:PropertyShape ;
    sh:name "toRdfTypes" ;
    sh:nodeKind sh:IRI ;
    sh:path shaclmate:toRdfType .

shaclmate:Ontology
    sh:property shaclmate:tsFeatureExcludes, shaclmate:tsFeatureIncludes, shaclmate:tsImports, shaclmate:tsObjectDeclarationType .

shaclmate:PropertyShape
    sh:property shaclmate:PropertyShape-resolve, shaclmate:PropertyShape-visibility, shaclmate:Shape-mutable, shaclmate:Shape-name .

shaclmate:PropertyShape-resolve
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:name "resolve" ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path shaclmate:resolve .

shaclmate:PropertyShape-visibility
    a sh:PropertyShape ;
    sh:in (shaclmate:_Visibility_Private
        shaclmate:_Visibility_Protected
        shaclmate:_Visibility_Public
    ) ;
    sh:maxCount 1 ;
    sh:path shaclmate:visibility .

shaclmate:Shape-mutable
    a sh:PropertyShape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:path shaclmate:mutable .

shaclmate:Shape-name
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:maxCount 1 ;
    sh:name "name" ;
    sh:path shaclmate:name .

shaclmate:tsFeatureExcludes
    a sh:PropertyShape ;
    sh:in (shaclmate:_TsFeatures_All
        shaclmate:_TsFeature_Create
        shaclmate:_TsFeatures_Default
        shaclmate:_TsFeature_Equals
        shaclmate:_TsFeature_Graphql
        shaclmate:_TsFeature_Hash
        shaclmate:_TsFeature_Json
        shaclmate:_TsFeatures_None
        shaclmate:_TsFeature_Rdf
        shaclmate:_TsFeature_Sparql
    ) ;
    sh:name "tsFeatureExcludes" ;
    sh:path shaclmate:tsFeatureExclude .

shaclmate:tsFeatureIncludes
    a sh:PropertyShape ;
    sh:in (shaclmate:_TsFeatures_All
        shaclmate:_TsFeature_Create
        shaclmate:_TsFeatures_Default
        shaclmate:_TsFeature_Equals
        shaclmate:_TsFeature_Graphql
        shaclmate:_TsFeature_Hash
        shaclmate:_TsFeature_Json
        shaclmate:_TsFeatures_None
        shaclmate:_TsFeature_Rdf
        shaclmate:_TsFeature_Sparql
    ) ;
    sh:name "tsFeatureIncludes" ;
    sh:path shaclmate:tsFeatureInclude .

shaclmate:tsImports
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "tsImports" ;
    sh:path shaclmate:tsImport .

shaclmate:tsObjectDeclarationType
    a sh:PropertyShape ;
    sh:in (shaclmate:_TsObjectDeclarationType_Class
        shaclmate:_TsObjectDeclarationType_Interface
    ) ;
    sh:maxCount 1 ;
    sh:path shaclmate:tsObjectDeclarationType .

