@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix shaclmate: <http://purl.org/shaclmate/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://purl.org/shaclmate/ontology#>
    shaclmate:tsFeatureInclude shaclmate:_TsFeature_Rdf ;
    shaclmate:tsObjectDeclarationType shaclmate:_TsObjectDeclarationType_Interface ;
    a owl:Ontology ;
    rdfs:comment "The shapes in this ontology are modeled after shacl-shacl but are intended for code generation with shaclmate rather than validation." ;
    rdfs:label "SHACL for shacl-ast" ;
    rdfs:seeAlso <https://www.w3.org/TR/shacl/#shacl-shacl> .

shaclmate:IdentifierList
    a owl:Class, sh:NodeShape ;
    rdfs:subClassOf rdf:List ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:nodeKind sh:BlankNodeOrIRI ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node shaclmate:IdentifierList ;
                sh:path rdf:rest
            ]
        ]
    ) .

shaclmate:InList
    a owl:Class, sh:NodeShape ;
    rdfs:subClassOf rdf:List ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:nodeKind sh:IRIOrLiteral ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node shaclmate:InList ;
                sh:path rdf:rest
            ]
        ]
    ) .

shaclmate:IriList
    a owl:Class, sh:NodeShape ;
    rdfs:subClassOf rdf:List ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:nodeKind sh:IRI ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node shaclmate:IriList ;
                sh:path rdf:rest
            ]
        ]
    ) .

shaclmate:NodeShape
    shaclmate:fromRdfType sh:NodeShape ;
    a owl:Class, sh:NodeShape ;
    sh:property shaclmate:NodeShape-closed, shaclmate:NodeShape-ignoredProperties, shaclmate:NodeShape-properties, shaclmate:Shape-and, shaclmate:Shape-classes, shaclmate:Shape-comments, shaclmate:Shape-datatype, shaclmate:Shape-deactivated, shaclmate:Shape-flags, shaclmate:Shape-hasValues, shaclmate:Shape-in, shaclmate:Shape-isDefinedBy, shaclmate:Shape-labels, shaclmate:Shape-languageIn, shaclmate:Shape-maxCount, shaclmate:Shape-maxExclusive, shaclmate:Shape-maxInclusive, shaclmate:Shape-maxLength, shaclmate:Shape-minCount, shaclmate:Shape-minExclusive, shaclmate:Shape-minInclusive, shaclmate:Shape-minLength, shaclmate:Shape-nodeKind, shaclmate:Shape-nodes, shaclmate:Shape-not, shaclmate:Shape-or, shaclmate:Shape-patterns, shaclmate:Shape-xone .

shaclmate:NodeShape-closed
    a sh:PropertyShape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:path sh:closed .

shaclmate:NodeShape-ignoredProperties
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:node shaclmate:IriList ;
    sh:path sh:ignoredProperties .

shaclmate:NodeShape-properties
    a sh:PropertyShape ;
    sh:name "properties" ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path sh:property .

shaclmate:Ontology
    shaclmate:fromRdfType owl:Ontology ;
    a owl:Class, sh:NodeShape ;
    sh:property shaclmate:Ontology-labels .

shaclmate:Ontology-labels
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "labels" ;
    sh:path rdfs:label .

shaclmate:PropertyGroup
    shaclmate:fromRdfType sh:PropertyGroup ;
    a sh:NodeShape ;
    sh:property shaclmate:PropertyGroup-comments, shaclmate:PropertyGroup-labels .

shaclmate:PropertyGroup-comments
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "comments" ;
    sh:path rdfs:comment .

shaclmate:PropertyGroup-labels
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "labels" ;
    sh:path rdfs:label .

shaclmate:PropertyPath
    shaclmate:extern true ;
    shaclmate:name "$PropertyPath" ;
    a sh:NodeShape ;
    rdfs:comment "Extern PropertyPath since shaclmate is not sophisticated enough to deal with all property path variants yet" .

shaclmate:PropertyShape
    shaclmate:fromRdfType sh:PropertyShape ;
    a owl:Class, sh:NodeShape ;
    sh:property shaclmate:PropertyShape-defaultValue, shaclmate:PropertyShape-descriptions, shaclmate:PropertyShape-groups, shaclmate:PropertyShape-names, shaclmate:PropertyShape-order, shaclmate:PropertyShape-path, shaclmate:PropertyShape-uniqueLang, shaclmate:Shape-and, shaclmate:Shape-classes, shaclmate:Shape-comments, shaclmate:Shape-datatype, shaclmate:Shape-deactivated, shaclmate:Shape-flags, shaclmate:Shape-hasValues, shaclmate:Shape-in, shaclmate:Shape-isDefinedBy, shaclmate:Shape-labels, shaclmate:Shape-languageIn, shaclmate:Shape-maxCount, shaclmate:Shape-maxExclusive, shaclmate:Shape-maxInclusive, shaclmate:Shape-maxLength, shaclmate:Shape-minCount, shaclmate:Shape-minExclusive, shaclmate:Shape-minInclusive, shaclmate:Shape-minLength, shaclmate:Shape-nodeKind, shaclmate:Shape-nodes, shaclmate:Shape-not, shaclmate:Shape-or, shaclmate:Shape-patterns, shaclmate:Shape-xone .

shaclmate:PropertyShape-defaultValue
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRIOrLiteral ;
    sh:path sh:defaultValue .

shaclmate:PropertyShape-descriptions
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "descriptions" ;
    sh:path sh:description .

shaclmate:PropertyShape-groups
    a sh:PropertyShape ;
    sh:name "groups" ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path sh:group .

shaclmate:PropertyShape-names
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "names" ;
    sh:path sh:name .

shaclmate:PropertyShape-order
    a sh:PropertyShape ;
    sh:datatype xsd:double ;
    sh:maxCount 1 ;
    sh:path sh:order .

shaclmate:PropertyShape-path
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:minCount 1 ;
    sh:node shaclmate:PropertyPath ;
    sh:path sh:path .

shaclmate:PropertyShape-uniqueLang
    a sh:PropertyShape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:path sh:uniqueLang .

shaclmate:Shape
    a sh:NodeShape ;
    sh:xone (shaclmate:NodeShape
        shaclmate:PropertyShape
    ) .

shaclmate:Shape-and
    a sh:PropertyShape ;
    sh:node shaclmate:IdentifierList ;
    sh:path sh:and .

shaclmate:Shape-classes
    a sh:PropertyShape ;
    sh:name "classes" ;
    sh:nodeKind sh:IRI ;
    sh:path sh:class .

shaclmate:Shape-comments
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "comments" ;
    sh:path rdfs:comment .

shaclmate:Shape-datatype
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:IRI ;
    sh:path sh:datatype .

shaclmate:Shape-deactivated
    a sh:PropertyShape ;
    sh:datatype xsd:boolean ;
    sh:maxCount 1 ;
    sh:path sh:deactivated .

shaclmate:Shape-flags
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:path sh:flags .

shaclmate:Shape-hasValues
    a sh:PropertyShape ;
    sh:name "hasValues" ;
    sh:nodeKind sh:IRIOrLiteral ;
    sh:path sh:hasValue .

shaclmate:Shape-in
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:name "in_" ;
    sh:node shaclmate:InList ;
    sh:path sh:in .

shaclmate:Shape-isDefinedBy
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path rdfs:isDefinedBy .

shaclmate:Shape-labels
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "labels" ;
    sh:path rdfs:label .

shaclmate:Shape-languageIn
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:node shaclmate:StringList ;
    sh:path sh:languageIn .

shaclmate:Shape-maxCount
    a sh:PropertyShape ;
    sh:datatype xsd:unsignedInt ;
    sh:maxCount 1 ;
    sh:path sh:maxCount .

shaclmate:Shape-maxExclusive
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:Literal ;
    sh:path sh:maxExclusive .

shaclmate:Shape-maxInclusive
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:Literal ;
    sh:path sh:maxInclusive .

shaclmate:Shape-maxLength
    a sh:PropertyShape ;
    sh:datatype xsd:unsignedInt ;
    sh:maxCount 1 ;
    sh:path sh:maxLength .

shaclmate:Shape-minCount
    a sh:PropertyShape ;
    sh:datatype xsd:unsignedInt ;
    sh:maxCount 1 ;
    sh:path sh:minCount .

shaclmate:Shape-minExclusive
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:Literal ;
    sh:path sh:minExclusive .

shaclmate:Shape-minInclusive
    a sh:PropertyShape ;
    sh:maxCount 1 ;
    sh:nodeKind sh:Literal ;
    sh:path sh:minInclusive .

shaclmate:Shape-minLength
    a sh:PropertyShape ;
    sh:datatype xsd:unsignedInt ;
    sh:maxCount 1 ;
    sh:path sh:minLength .

shaclmate:Shape-nodeKind
    a sh:PropertyShape ;
    sh:in (sh:BlankNode
        sh:BlankNodeOrIRI
        sh:BlankNodeOrLiteral
        sh:IRI
        sh:IRIOrLiteral
        sh:Literal
    ) ;
    sh:maxCount 1 ;
    sh:path sh:nodeKind .

shaclmate:Shape-nodes
    a sh:PropertyShape ;
    sh:name "nodes" ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path sh:node .

shaclmate:Shape-not
    a sh:PropertyShape ;
    sh:nodeKind sh:BlankNodeOrIRI ;
    sh:path sh:not .

shaclmate:Shape-or
    a sh:PropertyShape ;
    sh:node shaclmate:IdentifierList ;
    sh:path sh:or .

shaclmate:Shape-patterns
    a sh:PropertyShape ;
    sh:datatype xsd:string ;
    sh:name "patterns" ;
    sh:path sh:pattern .

shaclmate:Shape-xone
    a sh:PropertyShape ;
    sh:node shaclmate:IdentifierList ;
    sh:path sh:xone .

shaclmate:StringList
    a owl:Class, sh:NodeShape ;
    rdfs:subClassOf rdf:List ;
    sh:xone ([
            sh:hasValue ( )
        ]
        [
            sh:property [
                sh:datatype xsd:string ;
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:path rdf:first
            ], [
                sh:maxCount 1 ;
                sh:minCount 1 ;
                sh:node shaclmate:StringList ;
                sh:path rdf:rest
            ]
        ]
    ) .

